@{
    ViewData["Title"] = "About Us";
}

<div class="page-header bg-light text-center py-5">
    <div class="container mt-5 pt-4">
        <h1 class="display-4 fw-light mb-3">About Feline Gallery</h1>
        <p class="lead text-muted">Connecting art lovers with exceptional works from creators around the world since 2010.</p>
    </div>
</div>

<section class="about-story-section py-5">
    <div class="container my-5">
        <div class="row g-5 align-items-center">
            <div class="col-lg-6">
                <img src="~/images/about.jpg" class="img-fluid w-100" alt="Gallery" style="height: 500px; object-fit: cover;">
            </div>
            <div class="col-lg-6">
                <h2 class="display-6 fw-light mb-4">Our Story</h2>
                <p class="lead mb-4">Founded in 2010, Feline Gallery has been at the forefront of contemporary art, dedicated to discovering and promoting exceptional talent from around the world.</p>
                <p class="text-muted">Over the years, we've built a reputation for excellence, working with both established masters and emerging artists to bring their visions to a global audience. Our commitment to quality and authenticity has made us a trusted destination for collectors and art enthusiasts alike.</p>
            </div>
        </div>
    </div>
</section>

<section class="about-values-section py-5 bg-light">
    <div class="container my-5">
        <div class="text-center mb-5">
            <h2 class="display-6 fw-light">Our Values</h2>
        </div>
        <div class="row g-4">
            <div class="col-lg-3 col-md-6">
                <div class="value-card bg-white p-4 text-center h-100">
                    <h3 class="h5 mb-3 fw-medium">Quality</h3>
                    <p class="text-muted mb-0">We curate only the finest works, ensuring each piece meets our exacting standards of artistic excellence and craftsmanship.</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="value-card bg-white p-4 text-center h-100">
                    <h3 class="h5 mb-3 fw-medium">Authenticity</h3>
                    <p class="text-muted mb-0">Every artwork comes with a certificate of authenticity and comprehensive provenance documentation.</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="value-card bg-white p-4 text-center h-100">
                    <h3 class="h5 mb-3 fw-medium">Support</h3>
                    <p class="text-muted mb-0">We're committed to supporting artists and providing them with fair compensation for their creative work.</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="value-card bg-white p-4 text-center h-100">
                    <h3 class="h5 mb-3 fw-medium">Accessibility</h3>
                    <p class="text-muted mb-0">Making art accessible to collectors at all levels is at the heart of everything we do.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="about-team-section py-5">
    <div class="container my-5">
        <div class="text-center mb-5">
            <h2 class="display-6 fw-light">Our Team</h2>
        </div>
        <div class="row g-4">
            <div class="col-lg-4 col-md-6">
                <div class="team-member text-center">
                    <img src="~/images/team/member1.jpg" class="img-fluid w-100 mb-3" alt="Team Member" style="height: 300px; object-fit: cover;">
                    <h3 class="h5 mb-2 fw-normal">Emma Richardson</h3>
                    <p class="text-muted mb-0">Founder & Director</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="team-member text-center">
                    <img src="~/images/team/member2.jpg" class="img-fluid w-100 mb-3" alt="Team Member" style="height: 300px; object-fit: cover;">
                    <h3 class="h5 mb-2 fw-normal">Michael Chen</h3>
                    <p class="text-muted mb-0">Chief Curator</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="team-member text-center">
                    <img src="~/images/team/member3.jpg" class="img-fluid w-100 mb-3" alt="Team Member" style="height: 300px; object-fit: cover;">
                    <h3 class="h5 mb-2 fw-normal">Sofia Martinez</h3>
                    <p class="text-muted mb-0">Head of Artist Relations</p>
                </div>
            </div>
        </div>
    </div>
</section>