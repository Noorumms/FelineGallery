@{
    ViewData["Title"] = "Contact Us";
}

<div class="page-header bg-light text-center py-5">
    <div class="container mt-5 pt-4">
        <h1 class="display-4 fw-light mb-3">Contact Us</h1>
        <p class="lead text-muted">We'd love to hear from you. Get in touch with our team.</p>
    </div>
</div>

<section class="contact-section py-5">
    <div class="container my-5">
        <div class="row g-5">
            <div class="col-lg-7">
                <h2 class="h3 mb-4 fw-normal">Send us a Message</h2>
                <form asp-action="Submit" method="post">
                    <div class="mb-4">
                        <label for="name" class="form-label text-uppercase small fw-bold">Name</label>
                        <input type="text" id="name" name="name" class="form-control form-control-lg" required>
                    </div>
                    <div class="mb-4">
                        <label for="email" class="form-label text-uppercase small fw-bold">Email</label>
                        <input type="email" id="email" name="email" class="form-control form-control-lg" required>
                    </div>
                    <div class="mb-4">
                        <label for="subject" class="form-label text-uppercase small fw-bold">Subject</label>
                        <input type="text" id="subject" name="subject" class="form-control form-control-lg" required>
                    </div>
                    <div class="mb-4">
                        <label for="message" class="form-label text-uppercase small fw-bold">Message</label>
                        <textarea id="message" name="message" class="form-control form-control-lg" rows="6" required></textarea>
                    </div>
                    <button type="submit" class="btn btn-dark btn-lg w-100">Send Message</button>
                </form>
            </div>

            <div class="col-lg-5">
                <h2 class="h3 mb-4 fw-normal">Get in Touch</h2>
                <div class="contact-info-item mb-4">
                    <h3 class="h5 fw-bold mb-3">Visit Us</h3>
                    <p class="text-muted mb-0">123 Art Street<br>New York, NY 10001<br>United States</p>
                </div>
                <div class="contact-info-item mb-4">
                    <h3 class="h5 fw-bold mb-3">Hours</h3>
                    <p class="text-muted mb-0">Tuesday - Saturday: 10am - 6pm<br>Sunday: 12pm - 5pm<br>Monday: Closed</p>
                </div>
                <div class="contact-info-item mb-4">
                    <h3 class="h5 fw-bold mb-3">Contact</h3>
                    <p class="text-muted mb-0">Email: info@felinegallery.com<br>Phone: +1 (555) 123-4567</p>
                </div>
                <div class="contact-info-item">
                    <h3 class="h5 fw-bold mb-3">Follow Us</h3>
                    <div class="d-flex gap-3 flex-wrap">
                        <a href="#" class="text-dark text-decoration-none border-bottom border-dark">Instagram</a>
                        <a href="#" class="text-dark text-decoration-none border-bottom border-dark">Facebook</a>
                        <a href="#" class="text-dark text-decoration-none border-bottom border-dark">Twitter</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>