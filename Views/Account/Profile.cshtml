@model Feline_Gallery_v1.ViewModels.ProfileVM

@{
    ViewData["Title"] = "My Profile";
}

<div class="page-header bg-light text-center py-5">
    <div class="container mt-5 pt-4">
        <h1 class="display-4 fw-light mb-3">My Account</h1>
        <p class="lead text-muted mx-auto" style="max-width: 700px;">
            Manage your profile and preferences
        </p>
    </div>
</div>

<section class="profile-section py-5">
    <div class="container my-5">
        <div class="row g-5">
            <!-- Sidebar -->
            <div class="col-lg-3">
                <div class="bg-light p-4">
                    <h5 class="filter-label mb-4">Account Menu</h5>
                    <ul class="list-unstyled">
                        <li class="mb-3">
                            <a href="#profile" class="text-decoration-none text-dark d-flex align-items-center">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-2">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                                    <circle cx="12" cy="7" r="4"/>
                                </svg>
                                Profile Details
                            </a>
                        </li>
                        <li class="mb-3">
                            <a asp-area="" asp-controller="Order" asp-action="MyOrders" class="text-decoration-none text-muted d-flex align-items-center">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-2">
                                    <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                                    <line x1="3" y1="6" x2="21" y2="6"/>
                                    <path d="M16 10a4 4 0 0 1-8 0"/>
                                </svg>
                                My Orders
                            </a>
                        </li>
                        <li class="mb-3">
                            <a href="#settings" class="text-decoration-none text-muted d-flex align-items-center">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-2">
                                    <circle cx="12" cy="12" r="3"/>
                                    <path d="M12 1v6m0 6v6m5.66-13l-4.24 4.24m0 5.52L17.66 23M1 12h6m6 0h6m-13-5.66l4.24 4.24m5.52 0L23 17.66"/>
                                </svg>
                                Settings
                            </a>
                        </li>
                        <li>
                            <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                <button type="submit" class="btn btn-link text-decoration-none text-muted d-flex align-items-center p-0 border-0">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-2">
                                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                                        <polyline points="16 17 21 12 16 7"/>
                                        <line x1="21" y1="12" x2="9" y2="12"/>
                                    </svg>
                                    Logout
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Main Content -->
            <div class="col-lg-9">
                <div class="bg-light p-5">
                    <h3 class="h4 fw-light mb-4">Profile Information</h3>

                    <form asp-area="" asp-controller="Account" asp-action="UpdateProfile" method="post">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label asp-for="FirstName" class="form-label filter-label">First Name</label>
                                <input asp-for="FirstName" class="form-control form-control-lg" type="text" />
                                <span asp-validation-for="FirstName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="LastName" class="form-label filter-label">Last Name</label>
                                <input asp-for="LastName" class="form-control form-control-lg" type="text" />
                                <span asp-validation-for="LastName" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Email" class="form-label filter-label">Email Address</label>
                            <input asp-for="Email" class="form-control form-control-lg" type="email" readonly />
                            <small class="text-muted">Email cannot be changed</small>
                        </div>

                        <div class="mb-4">
                            <label asp-for="PhoneNumber" class="form-label filter-label">Phone Number</label>
                            <input asp-for="PhoneNumber" class="form-control form-control-lg" type="tel" />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Address" class="form-label filter-label">Address</label>
                            <textarea asp-for="Address" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-3">
                            <button type="submit" class="btn btn-dark btn-lg">Save Changes</button>
                        </div>
                    </form>
                </div>

                <!-- Account Stats -->
                <div class="row g-4 mt-4">
                    <div class="col-md-4">
                        <div class="bg-light p-4 text-center">
                            <h4 class="display-6 fw-light mb-2">@Model?.TotalOrders</h4>
                            <p class="text-muted mb-0 text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.5px;">Total Orders</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="bg-light p-4 text-center">
                            <h4 class="display-6 fw-light mb-2">@Model?.TotalSpent.ToString("C")</h4>
                            <p class="text-muted mb-0 text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.5px;">Total Spent</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="bg-light p-4 text-center">
                            <h4 class="display-6 fw-light mb-2">@Model?.MemberSince.ToString("MMM yyyy")</h4>
                            <p class="text-muted mb-0 text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.5px;">Member Since</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
        <partial name="_ValidationScriptsPartial" />
}