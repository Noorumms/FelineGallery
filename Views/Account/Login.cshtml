@model Feline_Gallery_v1.ViewModels.LoginVM

@{
    ViewData["Title"] = "Login";
}

<div class="page-header bg-light text-center py-5">
    <div class="container mt-5 pt-4">
        <h1 class="display-4 fw-light mb-3">Welcome Back</h1>
        <p class="lead text-muted mx-auto" style="max-width: 700px;">
            Sign in to your account to continue
        </p>
    </div>
</div>

<section class="login-section py-5">
    <div class="container my-5">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-7">
                <div class="bg-light p-5">
                    <form asp-area="" asp-controller="Account" asp-action="Login" method="post">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="Email" class="form-label filter-label">Email Address</label>
                            <input asp-for="Email" class="form-control form-control-lg" type="email" placeholder="your@email.com" required />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Password" class="form-label filter-label">Password</label>
                            <input asp-for="Password" class="form-control form-control-lg" type="password" placeholder="Enter your password" required />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="mb-4 form-check">
                            <input asp-for="RememberMe" class="form-check-input" type="checkbox" id="rememberMe">
                            <label class="form-check-label" for="rememberMe">
                                Remember me
                            </label>
                        </div>

                        <div class="d-grid mb-3">
                            <button type="submit" class="btn btn-dark btn-lg">Sign In</button>
                        </div>

                        <div class="text-center">
                            <a asp-area="" asp-controller="Account" asp-action="ForgotPassword" class="text-decoration-none text-muted">
                                Forgot Password?
                            </a>
                        </div>
                    </form>

                    <hr class="my-4">

                    <div class="text-center">
                        <p class="mb-0 text-muted">
                            Don't have an account? 
                            <a asp-area="" asp-controller="Account" asp-action="Register" class="text-dark text-decoration-none fw-medium">
                                Create Account
                            </a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
        <partial name="_ValidationScriptsPartial" />
}