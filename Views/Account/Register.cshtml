@model Feline_Gallery_v1.ViewModels.RegisterVM

@{
    ViewData["Title"] = "Register";
}

<div class="page-header bg-light text-center py-5">
    <div class="container mt-5 pt-4">
        <h1 class="display-4 fw-light mb-3">Create Account</h1>
        <p class="lead text-muted mx-auto" style="max-width: 700px;">
            Join Feline Gallery to discover and collect exceptional art
        </p>
    </div>
</div>

<section class="register-section py-5">
    <div class="container my-5">
        <div class="row justify-content-center">
            <div class="col-lg-6 col-md-8">
                <div class="bg-light p-5">
                    <form asp-area="" asp-controller="Account" asp-action="Register" method="post">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label asp-for="FirstName" class="form-label filter-label">First Name</label>
                                <input asp-for="FirstName" class="form-control form-control-lg" type="text" placeholder="John" required />
                                <span asp-validation-for="FirstName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="LastName" class="form-label filter-label">Last Name</label>
                                <input asp-for="LastName" class="form-control form-control-lg" type="text" placeholder="Doe" required />
                                <span asp-validation-for="LastName" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Email" class="form-label filter-label">Email Address</label>
                            <input asp-for="Email" class="form-control form-control-lg" type="email" placeholder="your@email.com" required />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Password" class="form-label filter-label">Password</label>
                            <input asp-for="Password" class="form-control form-control-lg" type="password" placeholder="Create a strong password" required />
                            <span asp-validation-for="Password" class="text-danger"></span>
                            <small class="text-muted">Minimum 6 characters</small>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label filter-label">Confirm Password</label>
                            <input asp-for="ConfirmPassword" class="form-control form-control-lg" type="password" placeholder="Re-enter password" required />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <div class="mb-4 form-check">
                            <input asp-for="AgreeToTerms" class="form-check-input" type="checkbox" id="agreeTerms" required>
                            <label class="form-check-label" for="agreeTerms">
                                I agree to the <a href="#" class="text-dark">Terms & Conditions</a> and <a href="#" class="text-dark">Privacy Policy</a>
                            </label>
                            <span asp-validation-for="AgreeToTerms" class="text-danger d-block"></span>
                        </div>

                        <div class="d-grid mb-3">
                            <button type="submit" class="btn btn-dark btn-lg">Create Account</button>
                        </div>
                    </form>

                    <hr class="my-4">

                    <div class="text-center">
                        <p class="mb-0 text-muted">
                            Already have an account? 
                            <a asp-area="" asp-controller="Account" asp-action="Login" class="text-dark text-decoration-none fw-medium">
                                Sign In
                            </a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
        <partial name="_ValidationScriptsPartial" />
}