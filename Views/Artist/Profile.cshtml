@{
    ViewData["Title"] = "Artist Profile";
}

<div class="artist-profile-header py-5">
    <div class="container my-5">
        <div class="row g-5">
            <div class="col-lg-3">
                <div class="artist-profile-image">
                    <img src="~/images/artists/artist01.jpg" class="img-fluid w-100" alt="Artist" style="height: 300px; object-fit: cover;">
                </div>
            </div>
            <div class="col-lg-9">
                <div class="artist-profile-info">
                    <h1 class="display-5 mb-2">Sarah Mitchell</h1>
                    <p class="artist-location text-muted mb-4">New York, USA</p>
                    <p class="artist-bio lead mb-4">
                        Sarah Mitchell is a contemporary abstract painter known for her vibrant use of color and dynamic compositions. Her work has been exhibited internationally and is held in numerous private collections.
                    </p>

                    <div class="artist-stats d-flex gap-5 mb-4">
                        <div class="stat">
                            <div class="stat-value display-6">15</div>
                            <div class="stat-label text-muted text-uppercase small">Years Active</div>
                        </div>
                        <div class="stat">
                            <div class="stat-value display-6">127</div>
                            <div class="stat-label text-muted text-uppercase small">Artworks</div>
                        </div>
                        <div class="stat">
                            <div class="stat-value display-6">8</div>
                            <div class="stat-label text-muted text-uppercase small">Exhibitions</div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<section class="artist-works-section py-5 bg-light">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <h2 class="display-6 mb-0">Available Artworks</h2>
        </div>

        <div class="row g-4">
            <!-- Artwork Cards -->
            <div class="col-lg-4 col-md-6">
                <a asp-controller="Artwork" asp-action="Details" asp-route-id="1" class="artwork-card text-decoration-none d-block">
                    <div class="artwork-image position-relative mb-3">
                        <img src="/images/artworks/artists-artwork/crimson-dreams.jpg" class="img-fluid w-100" style="height:350px; object-fit:cover;">
                        <div class="artwork-overlay position-absolute top-0 start-0 w-100 h-100 d-flex justify-content-center align-items-center">
                            <button class="btn btn-light rounded-circle btn-icon">
                                <svg width="24" height="24" stroke="currentColor" stroke-width="2" fill="none">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <line x1="12" y1="8" x2="12" y2="16"></line>
                                    <line x1="8" y1="12" x2="16" y2="12"></line>
                                </svg>
                            </button>
                        </div>
                    </div>
                    <div class="artwork-info px-2">
                        <h3 class="h5 mb-1 fw-normal">Crimson Dreams</h3>
                        <p class="text-muted small mb-2">Sarah Mitchell</p>
                        <p class="fw-bold mb-0">$2,500</p>
                    </div>
                </a>
            </div>

                        <div class="col-lg-4 col-md-6">
                <a asp-controller="Artwork" asp-action="Details" asp-route-id="1" class="artwork-card text-decoration-none d-block">
                    <div class="artwork-image position-relative mb-3">
                        <img src="~/images/artworks/artists-artwork/color-of-echoes.jpg" class="img-fluid w-100" style="height:350px; object-fit:cover;">
                        <div class="artwork-overlay position-absolute top-0 start-0 w-100 h-100 d-flex justify-content-center align-items-center">
                            <button class="btn btn-light rounded-circle btn-icon">
                                <svg width="24" height="24" stroke="currentColor" stroke-width="2" fill="none">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <line x1="12" y1="8" x2="12" y2="16"></line>
                                    <line x1="8" y1="12" x2="16" y2="12"></line>
                                </svg>
                            </button>
                        </div>
                    </div>
                    <div class="artwork-info px-2">
                        <h3 class="h5 mb-1 fw-normal">Color of Echoes</h3>
                        <p class="text-muted small mb-2">Sarah Mitchell</p>
                        <p class="fw-bold mb-0">$2,500</p>
                    </div>
                </a>
            </div>


            <div class="col-lg-4 col-md-6">
                <a asp-controller="Artwork" asp-action="Details" asp-route-id="2" class="artwork-card text-decoration-none d-block">
                    <div class="artwork-image position-relative mb-3">
                        <img src="~/images/artworks/artists-artwork/rise-of-dawn.jpg" class="img-fluid w-100" style="height:350px; object-fit:cover;">
                        <div class="artwork-overlay position-absolute top-0 start-0 w-100 h-100 d-flex justify-content-center align-items-center">
                            <button class="btn btn-light rounded-circle btn-icon">
                                <svg width="24" height="24" stroke="currentColor" stroke-width="2" fill="none">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <line x1="12" y1="8" x2="12" y2="16"></line>
                                    <line x1="8" y1="12" x2="16" y2="12"></line>
                                </svg>
                            </button>
                        </div>
                    </div>
                    <div class="artwork-info px-2">
                        <h3 class="h5 mb-1 fw-normal">Rise of dawn</h3>
                        <p class="text-muted small mb-2">Sarah Mitchell</p>
                        <p class="fw-bold mb-0">$5,000</p>
                    </div>
                </a>
            </div>

        </div>
    </div>
</section>

<section class="artist-exhibitions-section py-5">
    <div class="container">
        <div class="section-header mb-5">
            <h2 class="display-6">Exhibitions</h2>
        </div>

        <div class="row exhibition-list-item py-4 border-bottom">
            <div class="col-md-2">
                <span class="h4 text-muted">2024</span>
            </div>
            <div class="col-md-10">
                <h3 class="h5 mb-2">Abstract Expressions</h3>
                <p class="text-muted mb-0">Feline Gallery, New York</p>
            </div>
        </div>

        <div class="row exhibition-list-item py-4 border-bottom">
            <div class="col-md-2">
                <span class="h4 text-muted">2023</span>
            </div>
            <div class="col-md-10">
                <h3 class="h5 mb-2">Contemporary Visions</h3>
                <p class="text-muted mb-0">Modern Art Museum, Los Angeles</p>
            </div>
        </div>

    </div>
</section>
