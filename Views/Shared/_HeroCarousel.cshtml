
<section class="carousel-section">
    <div id="heroCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel" data-bs-interval="5000">
        <div class="carousel-inner">
            <div class="carousel-item active">
                <img src="~/images/Home/carousal/carousal01.jpg" class="d-block w-100 carousel-image" alt="Gallery 1">
            </div>
            <div class="carousel-item">
                <img src="~/images/Home/carousal/carousel02.jpg" class="d-block w-100 carousel-image" alt="Gallery 2">
            </div>
            <div class="carousel-item">
                <img src="~/images/Home/carousal/carousel03.jpg" class="d-block w-100 carousel-image" alt="Gallery 3">
            </div>
        </div>
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2" aria-label="Slide 3"></button>
        </div>
    </div>
</section>