@model Feline_Gallery_v1.Models.PaginatedList<Feline_Gallery_v1.Models.Artwork>
@{
    var category = ViewBag.Category as Feline_Gallery_v1.Models.Category;
    ViewData["Title"] = category?.Name ?? "Category";
}

<div class="category-hero bg-light text-center py-5">
    <div class="container my-5">
        <h1 class="display-3 fw-light mb-4">@category.Name</h1>
        @if (!string.IsNullOrEmpty(category.Description))
        {
                <p class="lead text-muted">@category.Description</p>
        }
    </div>
</div>

<div class="shop-filters-section py-4 border-bottom">
    <div class="container">
        <form method="get" asp-action="Details" asp-route-id="@category.CategoryId">
            <div class="row g-3">
                <div class="col-lg-6 col-md-6">
                    <label class="form-label filter-label">Sort By</label>
                    <select name="sortBy" class="form-select" onchange="this.form.submit()">
                        <option value="newest" selected="@(ViewBag.CurrentSort == "newest")">Newest First</option>
                        <option value="price_asc" selected="@(ViewBag.CurrentSort == "price_asc")">Price: Low to High</option>
                        <option value="price_desc" selected="@(ViewBag.CurrentSort == "price_desc")">Price: High to Low</option>
                        <option value="title" selected="@(ViewBag.CurrentSort == "title")">Title A-Z</option>
                    </select>
                </div>
                <div class="col-lg-6 col-md-6 d-flex align-items-end">
                    <a asp-controller="Shop" asp-action="Index" class="btn btn-outline-secondary w-100">
                        View All Artworks
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

@* Results Info *@
<div class="container mt-4">
    <p class="text-muted">
        Showing @Model.Items.Count of @Model.TotalCount artworks in @category.Name
        (Page @Model.PageIndex of @Model.TotalPages)
    </p>
</div>

<section class="shop-section py-5">
    <div class="container">
        <div class="row g-4">
            @if (Model.Items.Any())
            {
                @foreach (var artwork in Model.Items)
                {
                            <div class="col-lg-4 col-md-6">
                                <a asp-controller="Artwork" asp-action="Details" asp-route-id="@artwork.ArtworkId" 
                                   class="artwork-card text-decoration-none d-block">
                                    <div class="artwork-image position-relative mb-3">
                                        <img src="@artwork.ImageUrl" class="img-fluid w-100" alt="@artwork.Title" 
                                             style="height: 350px; object-fit: cover;">
                                        <div class="artwork-overlay position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center">
                                            <button class="btn btn-light rounded-circle btn-icon" type="button">
                                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <circle cx="12" cy="12" r="10"/>
                                                    <line x1="12" y1="8" x2="12" y2="16"/>
                                                    <line x1="8" y1="12" x2="16" y2="12"/>
                                                </svg>
                                            </button>
                                        </div>
                                    </div>
                                    <div class="artwork-info px-2">
                                        <h3 class="h5 mb-1 fw-normal">@artwork.Title</h3>
                                        <p class="artwork-artist text-muted mb-2 small">@artwork.Artist?.Name</p>
                                @if (!string.IsNullOrEmpty(artwork.Dimensions))
                                {
                                                <p class="artwork-specs text-muted small mb-2">@artwork.Dimensions</p>
                                }
                                        <p class="artwork-price fw-bold mb-0">$@artwork.Price.ToString("N2")</p>
                                    </div>
                                </a>
                            </div>
                }
            }
            else
            {
                    <div class="col-12 text-center py-5">
                        <p class="text-muted">No artworks found in this category.</p>
                    </div>
            }
        </div>

        @* Pagination Controls *@
        @if (Model.TotalPages > 1)
        {
                <nav class="pagination-section py-5">
                    <div class="container">
                        <ul class="pagination justify-content-center gap-2 flex-wrap">

                        @* Previous Button *@
                            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                                <a class="page-link" 
                                   asp-action="Details" 
                                   asp-route-id="@category.CategoryId"
                                   asp-route-page="@(Model.PageIndex - 1)"
                                   asp-route-sortBy="@ViewBag.CurrentSort">
                                    Previous
                                </a>
                            </li>

                        @* Page Numbers *@
                        @{
                            int startPage = Math.Max(1, Model.PageIndex - 2);
                            int endPage = Math.Min(Model.TotalPages, Model.PageIndex + 2);
                        }

                        @for (int i = startPage; i <= endPage; i++)
                        {
                                    <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                                        <a class="page-link" 
                                           asp-action="Details" 
                                           asp-route-id="@category.CategoryId"
                                           asp-route-page="@i"
                                           asp-route-sortBy="@ViewBag.CurrentSort">
                                    @i
                                        </a>
                                    </li>
                        }

                        @* Next Button *@
                            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                                <a class="page-link" 
                                   asp-action="Details" 
                                   asp-route-id="@category.CategoryId"
                                   asp-route-page="@(Model.PageIndex + 1)"
                                   asp-route-sortBy="@ViewBag.CurrentSort">
                                    Next
                                </a>
                            </li>
                        </ul>
                    </div>
                </nav>
        }
    </div>
</section>