@model Feline_Gallery_v1.ViewModels.CartVM

@{
    ViewData["Title"] = "Shopping Cart";
}

@* Success/Error Messages *@
@if (TempData["SuccessMessage"] != null)
{
        <div class="alert alert-success alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3" style="z-index: 9999; width: auto;" role="alert">
            <strong>Success!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
}

@if (TempData["ErrorMessage"] != null)
{
        <div class="alert alert-danger alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3" style="z-index: 9999; width: auto;" role="alert">
            <strong>Error!</strong> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
}

<div class="page-header-simple text-center py-5">
    <div class="container mt-5 pt-4">
        <h1 class="display-5 fw-light">Shopping Cart</h1>
    </div>
</div>

<section class="cart-section py-5">
    <div class="container">
        @if (Model.Cart.Items == null || Model.Cart.Items.Count == 0)
        {
                <div class="text-center py-5">
                    <svg width="100" height="100" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="mb-4">
                        <circle cx="9" cy="21" r="1"></circle>
                        <circle cx="20" cy="21" r="1"></circle>
                        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                    </svg>
                    <h3 class="mb-4">Your cart is empty</h3>
                    <p class="text-muted mb-4">Looks like you haven't added any artworks yet.</p>
                    <a asp-controller="Shop" asp-action="Index" class="btn btn-dark btn-lg">Continue Shopping</a>
                </div>
        }
        else
        {
                <div class="row g-5">
                    <div class="col-lg-8">
                        <div class="cart-items">
                        @foreach (var item in Model.Cart.Items)
                        {
                                    <div class="cart-item border p-4 mb-4">
                                        <div class="row g-4 align-items-center">
                                            <div class="col-md-3 col-sm-4">
                                                <img src="@(item.ImageUrl ?? "/images/placeholder.jpg")" class="img-fluid w-100" alt="@item.Title" style="height: 150px; object-fit: cover;">
                                            </div>
                                            <div class="col-md-5 col-sm-8">
                                                <h3 class="h5 mb-2 fw-normal">@item.Title</h3>
                                                <p class="text-muted mb-1 small">@item.ArtistName</p>
                                                <p class="text-muted small mb-0">Quantity: @item.Quantity</p>
                                            </div>
                                            <div class="col-md-3 col-6">
                                                <p class="h4 mb-0">$@item.Price.ToString("N2")</p>
                                            </div>
                                            <div class="col-md-1 col-6 text-end">
                                                <form asp-controller="Cart" asp-action="RemoveFromCart" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                                    <input type="hidden" name="artworkId" value="@item.ArtworkId" />
                                                    <button type="submit" class="btn btn-link text-muted p-0" title="Remove from cart">
                                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                            <line x1="18" y1="6" x2="6" y2="18"/>
                                                            <line x1="6" y1="6" x2="18" y2="18"/>
                                                        </svg>
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                        }
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="cart-summary bg-light p-4 sticky-top" style="top: 100px;">
                            <h3 class="h5 text-uppercase fw-bold mb-4">Order Summary</h3>
                            <div class="d-flex justify-content-between py-3 border-bottom">
                                <span>Subtotal (@Model.Cart.Items.Sum(x => x.Quantity) items)</span>
                                <span>$@Model.Cart.Items.Sum(x => x.Price * x.Quantity).ToString("N2")</span>
                            </div>
                            <div class="d-flex justify-content-between py-3 border-bottom">
                                <span>Shipping</span>
                                <span>@(Model.ShippingCost == 0 ? "Free" : "$" + Model.ShippingCost.ToString("N2"))</span>
                            </div>
                            <div class="d-flex justify-content-between py-3 border-top border-dark h5 mb-0 mt-3">
                                <span>Total</span>
                                <span>$@Model.GrandTotal.ToString("N2")</span>
                            </div>
                            <a asp-controller="Checkout" asp-action="Index" class="btn btn-dark w-100 btn-lg mt-4 mb-3">Proceed to Checkout</a>
                            <a asp-controller="Shop" asp-action="Index" class="btn btn-link text-dark w-100 text-center text-decoration-none">Continue Shopping</a>

                            <form asp-controller="Cart" asp-action="ClearCart" method="post" class="mt-3">
                            @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger w-100" onclick="return confirm('Are you sure you want to clear your cart?')">Clear Cart</button>
                            </form>
                        </div>
                    </div>
                </div>
        }
    </div>
</section>

@* Auto-dismiss alerts after 5 seconds *@
@section Scripts {
        <script>
            setTimeout(function() {
                var alerts = document.querySelectorAll('.alert');
                alerts.forEach(function(alert) {
                    var bsAlert = new bootstrap.Alert(alert);
                    bsAlert.close();
                });
            }, 5000);
        </script>
}